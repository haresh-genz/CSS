*- --- -- --- -CSS:

.product-card {
  width: 250px;
  padding: 20px;
  border: 2px solid black;
  box-sizing: border-box;
  margin: 50px auto;
  display: inline-block;
  transition: all 0.3s ease;
  border-radius: 25px;
}

.product-card:hover {
  border: 4px solid rgb(7, 235, 224);
}

.addtocart {
  color: rgb(7, 214, 186);
  background: rgb(49, 48, 53);
  height: 100%;
  width: 100%;
  font-family: monospace;
  padding: 20px;
  font-size: 15px;
}

#card-2 {
  background-color: rgb(216, 21, 200);
}


